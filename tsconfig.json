{
  "compilerOptions": {
    "module": "nodenext",
    "lib": ["ESNext", "DOM"],
    "target": "es2015",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "typeRoots": ["./node_modules/@types", "./@types", "./node_modules/@types/typed-screeps-arena/dist"],
    "types": ["typed-screeps-arena"],
    "paths": {
      "@/*": ["./src/*"],
      "game/*": ["./node_modules/@types/typed-screeps-arena/dist/game/*"],
      "arena/*": ["./node_modules/@types/typed-screeps-arena/dist/arena/*"]
    }
  },
  "exclude": ["node_modules", "dist", "old_src"]
}
