{
  "name": "typescript-screeps-arena-v3",
  "module": "src/advanced-spawn-and-swamp/main.ts",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "rm -rf dist && node esbuild.config.mjs default",
    "build:prod": "rm -rf dist && NODE_ENV=production node esbuild.config.mjs default --prod",
    "build:watch": "node esbuild.config.mjs default --watch",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "checkall": "pnpm run format && pnpm run lint && pnpm run check && pnpm run typecheck",
    "update-arena-types": "pnpm remove @types/typed-screeps-arena && pnpm add @types/typed-screeps-arena@github:kounoike/typed-screeps-arena#develop",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@typescript/native-preview": "7.0.0-dev.20251109.1",
    "ansi-escapes": "^7.2.0",
    "chokidar": "^3.6.0",
    "cli-columns": "^4.0.0",
    "cli-cursor": "^5.0.0",
    "cloc": "1.98.0-cloc",
    "esbuild": "^0.26.0",
    "glob": "^13.0.6",
    "lefthook": "^2.0.4",
    "log-update": "^7.0.2"
  },
  "peerDependencies": {
    "@types/lodash": "^4.14.202"
  },
  "dependencies": {
    "@types/typed-screeps-arena": "github:kounoike/typed-screeps-arena#develop",
    "ansi-colors": "^4.1.3",
    "ansi-styles": "^6.2.3",
    "base64-js": "^1.5.1",
    "lodash": "^4.17.21",
    "loglevel": "^1.9.2",
    "typescript": "^5.9.3",
    "utf8-buffer": "^1.0.0"
  },
  "private": true
}
